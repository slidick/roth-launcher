	SDLK_RSHIFT: KEY_SHIFT,
	SDLK_RCTRL: KEY_CTRL,
	SDLK_RALT: KEY_ALT,
	SDLK_RMETA: KEY_META,
}


static func godot_to_sdl(event: InputEvent) -> int:
	match event.location:
		KEY_LOCATION_RIGHT:
			return _godot_to_sdl_right[event.keycode]
		_:
			if event.keycode in _godot_to_sdl:
				return _godot_to_sdl[event.keycode]
			else:
				return -1


static func sdl_to_godot_string(keycode: int) -> String:
	if keycode in _sdl_to_godot:
		if (keycode == SDLK_LALT or 
				keycode == SDLK_LCTRL or 
				keycode == SDLK_LSHIFT or
				keycode == SDLK_LMETA):
			return "Left"+OS.get_keycode_string(_sdl_to_godot[keycode])
		else:
			return OS.get_keycode_string(_sdl_to_godot[keycode])
		
	elif keycode in _sdl_to_godot_right:
		return "Right"+OS.get_keycode_string(_sdl_to_godot_right[keycode])
	else:
		return "Invalid"


static func get_sdl_keycode_string(keycode_array: Array) -> String:
	var keycode_string: String = ""
	for keycode: String in keycode_array:
		keycode_string += ' "key %s"' % keycode
	return keycode_string.lstrip(" ")
